{
  "name": "leva-app",
  "version": "1.0.0",
  "description": "Aplicativo de transporte estilo Uber",
  "main": "backend/server.js",
  "scripts": {
    "start": "node src/app.js",
    "build": "cd frontend && npm install && npm run build && cd ../backend && npm install",
    "dev": "nodemon src/app.js",
    "install-deps": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "setup": "node src/scripts/setupDatabase.js",
    "migrate": "node src/scripts/migrateBoraMoveDb.js"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@reach/combobox": "^0.18.0",
    "@react-google-maps/api": "^2.20.6",
    "concurrently": "^8.2.2",
    "use-places-autocomplete": "^4.0.1"
  }
}
